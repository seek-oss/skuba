{
  "compilerOptions": {
    "skipLibCheck": true, // tsdown has optional peer deps
    "customConditions": ["@seek/skuba/source"],
    "rootDir": ".",
    "declaration": true,
    "lib": ["ES2023"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "lib",
    "removeComments": false,
    "target": "ES2023"
  },
  "exclude": ["lib*/**/*"],
  "extends": "../../config/tsconfig.json"
}
