{
  "name": "eslint-config-skuba",
  "version": "8.1.0",
  "private": false,
  "description": "ESLint config for skuba",
  "homepage": "https://github.com/seek-oss/skuba/tree/main/packages/eslint-config-skuba#readme",
  "bugs": {
    "url": "https://github.com/seek-oss/skuba/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seek-oss/skuba.git",
    "directory": "packages/eslint-config-skuba"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./extensions": {
      "import": "./lib/extensions.mjs",
      "require": "./lib/extensions.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "pnpm skuba build-package",
    "format": "pnpm --silent skuba format",
    "lint": "pnpm --silent skuba lint",
    "skuba": "node ../../lib/skuba",
    "test:ci": "echo \"No tests\""
  },
  "dependencies": {
    "eslint-config-seek": "15.0.4",
    "eslint-plugin-skuba": "workspace:*",
    "eslint-plugin-yml": "^1.14.0",
    "typescript-eslint": "^8.39.0"
  },
  "devDependencies": {
    "eslint": "^10.0.0",
    "jiti": "^2.6.1",
    "typescript": "~5.9.0"
  },
  "peerDependencies": {
    "eslint": ">=9.22.0",
    "typescript": ">=5.5.4"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.14.0"
  },
  "skuba": {
    "entryPoint": "index.js",
    "template": "oss-npm-package",
    "type": "package",
    "version": "15.3.0"
  }
}
