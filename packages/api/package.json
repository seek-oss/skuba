{
  "name": "@skuba-lib/api",
  "version": "2.2.0",
  "description": "Node.js development API for skuba",
  "homepage": "https://github.com/seek-oss/skuba#readme",
  "bugs": {
    "url": "https://github.com/seek-oss/skuba/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seek-oss/skuba.git",
    "directory": "packages/api"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "@seek/skuba/source": "./src/index.ts",
      "default": "./lib/index.mjs"
    },
    "./buildkite": {
      "@seek/skuba/source": "./src/buildkite/index.ts",
      "default": "./lib/buildkite/index.mjs"
    },
    "./cdk": {
      "@seek/skuba/source": "./src/cdk/index.ts",
      "default": "./lib/cdk/index.mjs"
    },
    "./cdk/nodejsFunction": {
      "@seek/skuba/source": "./src/cdk/nodejsFunction/index.ts",
      "default": "./lib/cdk/nodejsFunction/index.mjs"
    },
    "./git": {
      "@seek/skuba/source": "./src/git/index.ts",
      "default": "./lib/git/index.mjs"
    },
    "./github": {
      "@seek/skuba/source": "./src/github/index.ts",
      "default": "./lib/github/index.mjs"
    },
    "./net": {
      "@seek/skuba/source": "./src/net/index.ts",
      "default": "./lib/net/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/index.d.mts",
  "files": [
    "lib",
    "buildkite",
    "cdk",
    "git",
    "github",
    "net"
  ],
  "scripts": {
    "build": "pnpm skuba build-package",
    "skuba": "node ../../lib/skuba",
    "test": "pnpm skuba test",
    "test:ci": "pnpm skuba test --coverage"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.0",
    "@octokit/rest": "^22.0.0",
    "@octokit/types": "^16.0.0",
    "concurrently": "^10.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.0.0",
    "ignore": "^7.0.0",
    "isomorphic-git": "^1.37.6",
    "npm-run-path": "^6.0.0",
    "npm-which": "^3.0.1",
    "rolldown": "^1.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "aws-cdk-lib": "^2.253.0",
    "constructs": "^10.0.17"
  },
  "peerDependencies": {
    "aws-cdk-lib": ">=2.130.0",
    "constructs": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "aws-cdk-lib": {
      "optional": true
    },
    "constructs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "exports": {
      ".": "./lib/index.mjs",
      "./buildkite": "./lib/buildkite/index.mjs",
      "./cdk": "./lib/cdk/index.mjs",
      "./cdk/nodejsFunction": "./lib/cdk/nodejsFunction/index.mjs",
      "./git": "./lib/git/index.mjs",
      "./github": "./lib/github/index.mjs",
      "./net": "./lib/net/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
