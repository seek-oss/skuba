{
  "name": "@skuba-lib/api",
  "version": "2.1.0",
  "description": "Node.js development API for skuba",
  "homepage": "https://github.com/seek-oss/skuba#readme",
  "bugs": {
    "url": "https://github.com/seek-oss/skuba/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seek-oss/skuba.git",
    "directory": "packages/api"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "@seek/skuba/source": "./src/index.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./buildkite": {
      "@seek/skuba/source": "./src/buildkite/index.ts",
      "import": "./lib/buildkite/index.mjs",
      "require": "./lib/buildkite/index.cjs"
    },
    "./git": {
      "@seek/skuba/source": "./src/git/index.ts",
      "import": "./lib/git/index.mjs",
      "require": "./lib/git/index.cjs"
    },
    "./github": {
      "@seek/skuba/source": "./src/github/index.ts",
      "import": "./lib/github/index.mjs",
      "require": "./lib/github/index.cjs"
    },
    "./net": {
      "@seek/skuba/source": "./src/net/index.ts",
      "import": "./lib/net/index.mjs",
      "require": "./lib/net/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.cts",
  "files": [
    "lib",
    "buildkite",
    "git",
    "github",
    "net"
  ],
  "scripts": {
    "build": "pnpm skuba build-package && ./scripts/fix-types.sh",
    "skuba": "node ../../lib/skuba",
    "test": "pnpm skuba test",
    "test:ci": "pnpm skuba test --coverage"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.0",
    "@octokit/rest": "^22.0.0",
    "@octokit/types": "^16.0.0",
    "fs-extra": "^11.0.0",
    "ignore": "^7.0.0",
    "isomorphic-git": "^1.37.6",
    "zod": "^4.3.5"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./lib/index.mjs",
        "require": "./lib/index.cjs"
      },
      "./buildkite": {
        "import": "./lib/buildkite/index.mjs",
        "require": "./lib/buildkite/index.cjs"
      },
      "./git": {
        "import": "./lib/git/index.mjs",
        "require": "./lib/git/index.cjs"
      },
      "./github": {
        "import": "./lib/github/index.mjs",
        "require": "./lib/github/index.cjs"
      },
      "./net": {
        "import": "./lib/net/index.mjs",
        "require": "./lib/net/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "inlinedDependencies": {
    "ansi-styles": "4.3.0",
    "chalk": "4.1.2",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "concurrently": "9.2.1",
    "cross-spawn": "7.0.6",
    "execa": "5.1.1",
    "get-stream": "6.0.1",
    "has-flag": "4.0.0",
    "human-signals": "2.1.0",
    "is-stream": "2.0.1",
    "isexe": "2.0.0",
    "merge-stream": "2.0.0",
    "mimic-fn": "2.1.0",
    "npm-path": "2.0.4",
    "npm-run-path": "4.0.1",
    "npm-which": "3.0.1",
    "onetime": "5.1.2",
    "path-key": "3.1.1",
    "rxjs": "7.8.2",
    "shebang-command": "2.0.0",
    "shebang-regex": "3.0.0",
    "shell-quote": "1.8.3",
    "signal-exit": "3.0.7",
    "strip-final-newline": "2.0.0",
    "supports-color": [
      "7.2.0",
      "8.1.1"
    ],
    "tree-kill": "1.2.2",
    "which": [
      "1.3.1",
      "2.0.2"
    ]
  }
}
