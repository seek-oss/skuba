{
  "compilerOptions": {
    "incremental": true,
    "isolatedModules": true,
    "module": "node20",
    "moduleResolution": "node16",
    "noUncheckedSideEffectImports": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "types": ["node", "vitest/globals"]
  },
  "extends": "tsconfig-seek"
}
